rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()    { return request.auth != null; }
    function uid()       { return request.auth.uid; }
    function isOwner(u)  { return isAuth() && uid() == u; }
    function role()      {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }
    function userDoc() { return get(/databases/$(database)/documents/users/$(uid())).data; }
    function isSuperAdmin() { return isAuth() && role() == 'super_admin'; }
    function isLegacyAdmin() { return isAuth() && role() == 'admin' && !('permissions' in userDoc()); }
    function hasPermission(permission) { return isAuth() && role() == 'admin' && ('permissions' in userDoc()) && permission in userDoc().permissions; }
    function can(permission) { return isSuperAdmin() || isLegacyAdmin() || hasPermission(permission); }
    function isAdmin()   { return isSuperAdmin() || isAuth() && role() == 'admin'; }
    function isModerator() { return isAuth() && role() == 'moderator'; }
    function isStaff() { return can('moderation.manage') || isModerator(); }
    function isPartner() { return isAuth() && (role() == 'partner' || role() == 'admin' || role() == 'super_admin'); }
    function isNotSuspended() {
      return get(/databases/$(database)/documents/users/$(uid())).data.isSuspended != true;
    }

    function isModerationUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'moderationNote', 'updatedAt']) &&
             request.resource.data.status in ['approved', 'rejected'];
    }

    function keepsProtectedFields() {
      return request.resource.data.status         == resource.data.status &&
             request.resource.data.isFeatured      == resource.data.isFeatured &&
             request.resource.data.isSponsored     == resource.data.isSponsored &&
             request.resource.data.isVerified      == resource.data.isVerified &&
             request.resource.data.moderationNote  == resource.data.moderationNote &&
             request.resource.data.highlightType       == resource.data.highlightType &&
             request.resource.data.highlightStatus     == resource.data.highlightStatus &&
             request.resource.data.highlightBadge      == resource.data.highlightBadge &&
             request.resource.data.highlightSections   == resource.data.highlightSections &&
             request.resource.data.highlightStartAt    == resource.data.highlightStartAt &&
             request.resource.data.highlightEndAt      == resource.data.highlightEndAt &&
             request.resource.data.highlightRank       == resource.data.highlightRank &&
             request.resource.data.highlightPaymentRef == resource.data.highlightPaymentRef &&
             request.resource.data.highlightAmount     == resource.data.highlightAmount;
    }

    // Bump de note valide : reviewCount +1 (ou 1 à la 1re écriture du champ),
    // avgRating borné 0–5. Bloque « avg=5, count=9999 » en un coup.
    function isValidRatingBump() {
      return request.resource.data.avgRating is number &&
             request.resource.data.avgRating >= 0 &&
             request.resource.data.avgRating <= 5 &&
             request.resource.data.reviewCount is int &&
             (
               (!('reviewCount' in resource.data) && request.resource.data.reviewCount == 1) ||
               (('reviewCount' in resource.data) && request.resource.data.reviewCount == resource.data.reviewCount + 1)
             );
    }

    // ── Experiences ──────────────────────────────────────────────────────
    match /experiences/{id} {
      allow read: if resource.data.isPublished == true || isStaff() ||
                     (isAuth() && resource.data.ownerId == uid());
      allow create: if can('content.manage') ||
                       (isPartner() && isNotSuspended() &&
                        request.resource.data.ownerId == uid() &&
                        request.resource.data.status == 'pending' &&
                        request.resource.data.isPublished == false);
      allow delete: if can('content.manage') ||
                       (isPartner() && resource.data.ownerId == uid());
      // Vues : +1 exactement (anti-triche), tolérant à l'absence initiale du
      // champ (documents seedés sans compteur). Note : dénormalisée et bornée.
      allow update: if can('content.manage') ||
                       (isModerator() && isModerationUpdate()) ||
                       (isPartner() && resource.data.ownerId == uid() &&
                        request.resource.data.ownerId == uid() &&
                        keepsProtectedFields()) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
                        (
                          (!('views' in resource.data) && request.resource.data.views == 1) ||
                          (('views' in resource.data) && request.resource.data.views == resource.data.views + 1)
                        )) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avgRating', 'reviewCount']) &&
                        isValidRatingBump());
    }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || can('users.manage');
      allow create: if isOwner(userId);
      allow update: if isSuperAdmin() ||
                       (hasPermission('users.manage') &&
                        resource.data.role != 'super_admin' &&
                        request.resource.data.role != 'super_admin' &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'permissions', 'isSuspended', 'suspendedReason', 'updatedAt'])) ||
                       (isOwner(userId) &&
                        (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
                        (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.permissions));
    }

    // ── Profil public partageable (Sprint 9) ─────────────────────────────
    // Aucune donnée sensible (pas d'email) — lecture publique volontaire.
    match /publicProfiles/{userId} {
      allow read:  if true;
      allow write: if can('users.manage') || isOwner(userId);
    }

    // ── Favorites ────────────────────────────────────────────────────────
    match /favorites/{favId} {
      allow read:   if isAuth() && resource.data.userId == uid();
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow delete: if isAuth() && resource.data.userId == uid();
    }

    // ── Completed Experiences ────────────────────────────────────────────
    match /completedExperiences/{docId} {
      allow read:   if can('content.manage') || (isAuth() && (resource == null || resource.data.userId == uid()));
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow delete: if can('content.manage');
    }

    // ── Challenges ───────────────────────────────────────────────────────
    match /challenges/{id} {
      allow read:  if true;
      allow write: if can('content.manage');
    }

    // ── Establishments ───────────────────────────────────────────────────
    match /establishments/{id} {
      allow read: if resource.data.status == 'approved' || isStaff() ||
                     (isAuth() && resource.data.ownerId == uid());
      allow create: if isAdmin() ||
                       (isPartner() && isNotSuspended() &&
                        request.resource.data.ownerId == uid() &&
                        request.resource.data.status == 'pending');
      allow update: if can('content.manage') ||
                       (isModerator() && isModerationUpdate()) ||
                       (isPartner() && resource.data.ownerId == uid() &&
                        request.resource.data.ownerId == uid() &&
                        keepsProtectedFields()) ||
                       (isAuth() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avgRating', 'reviewCount']) &&
                        isValidRatingBump());
      allow delete: if isAdmin() ||
                       (isPartner() && resource.data.ownerId == uid());
    }

    // ── Codes de passage (SECRET — jamais lisible publiquement) ───────────
    // Séparés du document établissement pour ne pas fuiter via la lecture
    // publique. Lecture/écriture réservées au propriétaire et à l'admin.
    match /establishmentCodes/{estId} {
      allow read, write:
        if isAdmin() ||
           (isAuth() &&
            get(/databases/$(database)/documents/establishments/$(estId)).data.ownerId == uid());
    }

    // ── Events ───────────────────────────────────────────────────────────
    match /events/{id} {
      allow read: if resource.data.status == 'approved' || isStaff() ||
                     (isAuth() && resource.data.organizerId == uid());
      allow create: if isAdmin() ||
                       (isPartner() && isNotSuspended() &&
                        request.resource.data.organizerId == uid() &&
                        request.resource.data.status == 'pending');
      allow update: if can('content.manage') ||
                       (isModerator() && isModerationUpdate()) ||
                       (isPartner() && resource.data.organizerId == uid() &&
                        request.resource.data.organizerId == uid() &&
                        keepsProtectedFields()) ||
                       (isAuth() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avgRating', 'reviewCount']) &&
                        isValidRatingBump());
      allow delete: if isAdmin() ||
                       (isPartner() && resource.data.organizerId == uid());
    }

    // ── Badges ───────────────────────────────────────────────────────────
    match /badges/{id} {
      allow read:  if true;
      allow write: if can('content.manage');
    }

    // ── Avis & notes (Sprint 4) ──────────────────────────────────────────
    match /reviews/{id} {
      allow read:   if !resource.data.isHidden || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == uid() &&
                       request.resource.data.rating is number &&
                       request.resource.data.rating >= 1 &&
                       request.resource.data.rating <= 5;
      allow update: if can('content.manage') ||
                       (isAuth() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isFlagged']));
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == uid());
    }

    // ── Résumés d'avis (agrégat) ─────────────────────────────────────────
    // Écrit par la transaction createReview. Contraint : count monotone (+1),
    // moyenne bornée 0–5 → bloque l'écrasement arbitraire.
    match /reviewSummaries/{id} {
      allow read: if true;
      allow create: if isAuth() &&
                       request.resource.data.count == 1 &&
                       request.resource.data.average is number &&
                       request.resource.data.average >= 0 &&
                       request.resource.data.average <= 5;
      allow update: if can('content.manage') ||
                       (isAuth() &&
                        request.resource.data.count == resource.data.count + 1 &&
                        request.resource.data.average is number &&
                        request.resource.data.average >= 0 &&
                        request.resource.data.average <= 5);
    }

    // ── Réclamations de défis (Sprint 6) ─────────────────────────────────
    match /challengeClaims/{id} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == uid();
    }

    // ── Passages certifiés (Sprint 6) ────────────────────────────────────
    // La CRÉATION valide le code côté règle via get() sur la collection secrète :
    // le client n'a jamais accès au code réel. Code erroné ⇒ refus.
    match /checkIns/{id} {
      allow read:   if can('content.manage') || (isAuth() && resource.data.userId == uid());
      allow create: if isAuth() &&
                       request.resource.data.userId == uid() &&
                       get(/databases/$(database)/documents/establishmentCodes/$(request.resource.data.establishmentId)).data.code
                         == request.resource.data.enteredCode;
    }

    // ── Tirage au sort mensuel (Sprint 6) ────────────────────────────────
    match /raffleWinners/{id} {
      allow read: if true;
      allow create: if can('marketing.manage');
    }

    // ── Journal de modération (Sprint 3) ─────────────────────────────────
    match /moderationLogs/{id} {
      allow read: if isStaff() ||
                     (isAuth() &&
                      ((resource.data.kind == 'establishment' &&
                        get(/databases/$(database)/documents/establishments/$(resource.data.targetId)).data.ownerId == uid()) ||
                       (resource.data.kind == 'event' &&
                        get(/databases/$(database)/documents/events/$(resource.data.targetId)).data.organizerId == uid())));
      allow create: if can('moderation.manage') || isModerator();
    }

    // ── Journal d'audit admin (Sprint 3) ─────────────────────────────────
    match /auditLogs/{id} {
      allow read, create: if can('audit.view');
    }

    // ── Rubriques dynamiques homepage ────────────────────────────────────
    match /sections/{id} {
      allow read: if true;
      allow create, update, delete: if can('content.manage');
    }

    // ── Encarts publicitaires ────────────────────────────────────────────
    match /ads/{id} {
      allow read: if true;
      allow create, delete: if can('content.manage');
      // Compteurs : +1 max chacun, sans toucher au contenu de l'encart.
      allow update: if can('content.manage') ||
                       (request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['views', 'clicks', 'updatedAt']) &&
                        request.resource.data.views  >= resource.data.views &&
                        request.resource.data.views  <= resource.data.views + 1 &&
                        request.resource.data.clicks >= resource.data.clicks &&
                        request.resource.data.clicks <= resource.data.clicks + 1);
    }

    // ── Pages éditables ──────────────────────────────────────────────────
    match /pages/{id} {
      allow read: if resource.data.isPublished == true || can('content.manage');
      allow create, update, delete: if can('content.manage');
    }

    // ── AppSettings ──────────────────────────────────────────────────────
    match /appSettings/{docId} {
      allow read:  if true;
      allow write: if can('content.manage');
    }

    // ── CMS — banners ────────────────────────────────────────────────────
    match /banners/{id} {
      allow read:  if true;
      allow write: if can('content.manage');
    }

    // ── CMS — categories ─────────────────────────────────────────────────
    match /categories/{id} {
      allow read:  if true;
      allow write: if can('content.manage');
    }

    match /categoryProposals/{id} {
      allow create: if isPartner() && request.resource.data.proposedBy == uid() && request.resource.data.status == 'pending';
      allow read, update, delete: if can('content.manage');
    }

    // ── CMS — campaigns ──────────────────────────────────────────────────
    match /campaigns/{id} {
      allow read:  if true;
      allow write: if can('content.manage');
    }
  }
}
